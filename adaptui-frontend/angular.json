{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "adaptui-frontend": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "sass",
          "standalone": false
        },
        "@schematics/angular:directive": {
          "standalone": false
        },
        "@schematics/angular:pipe": {
          "standalone": false
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "sass",
            "assets": [
              { "glob": "**/*", "input": "src/assets/", "output": "/assets/" },
              { "glob": "favicon.ico", "input": "src", "output": "/" }
            ],
            "styles": [
              "@angular/material/prebuilt-themes/azure-blue.css",
              "node_modules/@maxgraph/core/css/common.css",
              "src/styles.sass"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "2mb", "maximumError": "3mb" },
                { "type": "anyComponentStyle", "maximumWarning": "6kb", "maximumError": "8kb" }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "mxgraph": {
              "fileReplacements": [
                {
                  "replace": "src/app/graph/graph-backend.ts",
                  "with": "src/app/graph/graph-backend.mxgraph.ts"
                }
              ],
              "assets": [
                { "glob": "**/*", "input": "src/assets/", "output": "/assets/" },
                { "glob": "favicon.ico", "input": "src", "output": "/" },
                { "glob": "**/*", "input": "node_modules/mxgraph/javascript/src", "output": "/assets/mxgraph" }
              ],
              "styles": [
                "@angular/material/prebuilt-themes/azure-blue.css",
                "src/styles.sass"
              ],
              "scripts": [
                "src/config/mxgraph-config.js",
                "node_modules/mxgraph/javascript/mxClient.js"
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "adaptui-frontend:build:production"
            },
            "development": {
              "buildTarget": "adaptui-frontend:build:development"
            },
            "mxgraph": {
              "buildTarget": "adaptui-frontend:build:development,mxgraph"
            },
            "mxgraph-production": {
              "buildTarget": "adaptui-frontend:build:production,mxgraph"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "sass",
            "assets": [
              { "glob": "**/*", "input": "src/assets/", "output": "/assets/" },
              { "glob": "favicon.ico", "input": "src", "output": "/" }
            ],
            "styles": [
              "@angular/material/prebuilt-themes/azure-blue.css",
              "node_modules/@maxgraph/core/css/common.css",
              "src/styles.sass"
            ],
            "scripts": []
          }
        }
      }
    }
  }
}
