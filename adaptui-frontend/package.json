{
  "name": "adaptui-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:mxgraph": "ng serve --configuration mxgraph",
    "build": "ng build",
    "build:maxgraph": "ng build",
    "build:mxgraph": "ng build --configuration production,mxgraph",
    "build:pages": "ng build --base-href=/adaptui-web-ide/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:pipeline": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox --include='**/pipeline-from-scratch.spec.ts'"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.0",
    "@angular/cdk": "^20.2.0",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.2.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.3",
    "@maxgraph/core": "^0.23.0",
    "mxgraph": "^4.2.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.27",
    "@angular/cli": "^20.3.27",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "mxgraph-type-definitions": "^1.0.6",
    "typescript": "~5.9.2"
  }
}
